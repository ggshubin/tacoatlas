{
  "name": "tacooatlas",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.1",
    "@supabase/supabase-js": "^2.99.1",
    "expo": "~55.0.6",
    "expo-camera": "^55.0.9",
    "expo-image-picker": "^55.0.12",
    "expo-location": "^55.1.2",
    "expo-router": "^55.0.5",
    "expo-status-bar": "~55.0.4",
    "nanoid": "^5.1.7",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-maps": "^1.27.2",
    "react-native-mmkv": "^4.2.0",
    "react-native-url-polyfill": "^3.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "jest": "^30.3.0",
    "jest-expo": "^55.0.9",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.2"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "jsx": "react"
          }
        }
      ]
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts?(x)"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ],
    "moduleNameMapper": {
      "^react-native-mmkv$": "<rootDir>/src/__mocks__/react-native-mmkv.js",
      "^nanoid/non-secure$": "<rootDir>/src/__mocks__/nanoid.ts",
      "^react-native-url-polyfill/auto$": "<rootDir>/src/__mocks__/react-native-url-polyfill.ts",
      "^@react-native-async-storage/async-storage$": "<rootDir>/src/__mocks__/async-storage.ts"
    }
  },
  "private": true
}
