{
  "name": "tacooatlas",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.1",
    "@supabase/supabase-js": "^2.99.1",
    "expo": "^52.0.49",
    "expo-camera": "^14.1.0",
    "expo-image-picker": "^15.1.0",
    "expo-location": "^17.0.0",
    "expo-router": "^3.4.0",
    "expo-status-bar": "^1.11.0",
    "nanoid": "^5.1.7",
    "react": "18.3.1",
    "react-native": "^0.76.9",
    "react-native-maps": "^1.27.2",
    "react-native-mmkv": "^4.2.0",
    "react-native-url-polyfill": "^3.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~18.3.0",
    "jest": "^29.7.0",
    "jest-expo": "^52.0.0",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.2"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "jsx": "react"
          }
        }
      ]
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts?(x)"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ],
    "moduleNameMapper": {
      "^react-native$": "<rootDir>/src/__mocks__/react-native.ts",
      "^react-native-mmkv$": "<rootDir>/src/__mocks__/react-native-mmkv.js",
      "^nanoid/non-secure$": "<rootDir>/src/__mocks__/nanoid.ts",
      "^react-native-url-polyfill/auto$": "<rootDir>/src/__mocks__/react-native-url-polyfill.ts",
      "^@react-native-async-storage/async-storage$": "<rootDir>/src/__mocks__/async-storage.ts",
      "^expo-location$": "<rootDir>/src/__mocks__/expo-location.ts",
      "^expo-image-picker$": "<rootDir>/src/__mocks__/expo-image-picker.ts"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|expo-router|expo-status-bar|expo|expo-camera|expo-image-picker|expo-location)/)"
    ]
  },
  "private": true
}
