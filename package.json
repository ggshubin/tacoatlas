    "ios": "expo start --ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "expo": "~55.0.6",
    "expo-status-bar": "~55.0.4",
    "nanoid": "^5.1.7",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-mmkv": "^4.2.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
