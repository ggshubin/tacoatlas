{
  "name": "tacooatlas",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest"
  },
  "dependencies": {
    "@expo/log-box": "^55.0.6",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.99.1",
    "expo": "^55.0.7",
    "expo-camera": "~55.0.10",
    "expo-clipboard": "~55.0.9",
    "expo-constants": "~55.0.9",
    "expo-device": "~55.0.10",
    "expo-image-manipulator": "^55.0.11",
    "expo-image-picker": "~55.0.13",
    "expo-linking": "~55.0.8",
    "expo-location": "~55.1.4",
    "expo-navigation-bar": "~55.0.9",
    "expo-notifications": "~55.0.13",
    "expo-router": "~55.0.7",
    "expo-status-bar": "~55.0.4",
    "expo-updates": "~55.0.24",
    "jest-expo": "~55.0.11",
    "nanoid": "^5.1.7",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-maps": "^1.27.2",
    "react-native-purchases": "^9.14.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-url-polyfill": "^3.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.10",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.10",
    "react-native-svg-transformer": "^1.5.0",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.2"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "jsx": "react"
          }
        }
      ]
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts?(x)"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ],
    "moduleNameMapper": {
      "^react-native$": "<rootDir>/src/__mocks__/react-native.ts",
      "^react-native-mmkv$": "<rootDir>/src/__mocks__/react-native-mmkv.js",
      "^nanoid/non-secure$": "<rootDir>/src/__mocks__/nanoid.ts",
      "^react-native-url-polyfill/auto$": "<rootDir>/src/__mocks__/react-native-url-polyfill.ts",
      "^@react-native-async-storage/async-storage$": "<rootDir>/src/__mocks__/async-storage.ts",
      "^expo-location$": "<rootDir>/src/__mocks__/expo-location.ts",
      "^expo-image-picker$": "<rootDir>/src/__mocks__/expo-image-picker.ts",
      "^@expo/vector-icons$": "<rootDir>/src/__mocks__/@expo/vector-icons.ts",
      "^expo-updates$": "<rootDir>/src/__mocks__/expo-updates.ts"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|expo-router|expo-status-bar|expo|expo-camera|expo-image-picker|expo-location)/)"
    ]
  },
  "private": true
}
