{
  "expo": {
    "name": "TacoAtlas",
    "slug": "tacooatlas",
    "scheme": "tacooatlas",
    "version": "1.0.0",
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-location",
      [
        "expo-image-picker",
        { "photosPermission": "TacoAtlas needs photo access to attach images to your reviews." }
      ]
    ],
    "android": {
      "icon": "./assets/icon.png"
    },
    "ios": {
      "supportsTablet": true
    },
    "web": {
      "bundler": "metro"
    }
  }
}
