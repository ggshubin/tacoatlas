{
  "expo": {
    "name": "TacoAtlas",
    "slug": "tacooatlas",
    "scheme": "tacooatlas",
    "version": "1.3.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#18140F"
    },
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-location",
      [
        "expo-image-picker",
        {
          "photosPermission": "TacoAtlas needs photo access to attach images to your reviews."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/taco-icon.png",
          "color": "#F5A623",
          "androidMode": "default"
        }
      ]
    ],
    "android": {
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#18140F"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.tacooatlas.app",
      "versionCode": 2,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDvWs4orTUGdsKhu195FUWldN0OosGSrqQ"
        }
      },
      "navigationBar": {
        "visible": "immersive",
        "backgroundColor": "#18140F",
        "barStyle": "light-content"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tacooatlas.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "93ba132a-6393-4899-aa8a-b2c8c5436ee9"
      }
    }
  }
}
